{
    "name": "hydra/event",
    "description": "PSR-14 event dispatcher for Hydra PHP framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hydra\\Event\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hydra\\Event\\Tests\\": "tests/"
        }
    },
    "repositories": [
        { "type": "path", "url": "../core", "options": { "symlink": true } }
    ],
    "authors": [
        {
            "name": "William Hleucka",
            "email": "william.hleucka@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "hydra/core": "*",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
